# =============================================================================
# UBIS - Unidentified Body Identification System
# Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values
# Required variables are marked with [REQUIRED]
# =============================================================================

# ─── ENVIRONMENT ───────────────────────────────────────────────────────────────
# Set to "production" for Azure deployment, "development" for local development
ENVIRONMENT=development

# ─── JWT AUTHENTICATION [REQUIRED] ─────────────────────────────────────────────
# Secret key for JWT token signing - MUST be changed in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── DATABASE CONFIGURATION ────────────────────────────────────────────────────
# 
# OPTION A: SQLite (Development - default)
# Just set the path to the SQLite database file
SQLITE_PATH=./ubis.db

# OPTION B: PostgreSQL (Production - Azure Database for PostgreSQL)
# Either provide full DATABASE_URL or individual components
# DATABASE_URL=postgresql://username:password@hostname:5432/dbname?sslmode=require
#
# Or provide individual components:
# POSTGRES_HOST=your-server.postgres.database.azure.com
# POSTGRES_PORT=5432
# POSTGRES_DB=ubis
# POSTGRES_USER=your-admin-user
# POSTGRES_PASSWORD=your-secure-password

# ─── FILE STORAGE CONFIGURATION ────────────────────────────────────────────────
#
# OPTION A: Local Storage (Development - default)
# Files will be stored in these local directories
SUBMISSIONS_STORAGE_PATH=./uploads
REFERENCE_PHOTOS_PATH=./reference_photos

# OPTION B: Azure Blob Storage (Production)
# Connection string from Azure Portal > Storage Account > Access Keys
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccountname;AccountKey=yourkey;EndpointSuffix=core.windows.net
# AZURE_STORAGE_CONTAINER_UPLOADS=uploads
# AZURE_STORAGE_CONTAINER_REFERENCES=references
# AZURE_STORAGE_ACCOUNT_URL=https://youraccountname.blob.core.windows.net

# ─── VECTOR DATABASE (QDRANT) CONFIGURATION ────────────────────────────────────
#
# OPTION A: Local Persistent Storage (Development - default)
# Stores vectors in a local directory
QDRANT_URL=./qdrant_data

# OPTION B: In-Memory (Testing only - data lost on restart)
# QDRANT_URL=:memory:

# OPTION C: Local Docker
# docker run -p 6333:6333 qdrant/qdrant
# QDRANT_URL=http://localhost:6333

# OPTION D: Qdrant Cloud (Production)
# Get credentials from https://cloud.qdrant.io
# QDRANT_URL=https://your-cluster-id.region.cloud.qdrant.io:6333
# QDRANT_API_KEY=your-qdrant-cloud-api-key

# Collection name for face embeddings
QDRANT_COLLECTION=face_embeddings

# ─── AI MODEL SETTINGS ─────────────────────────────────────────────────────────
# Minimum confidence threshold for face detection
FACE_DETECTION_THRESHOLD=0.5

# ─── CORS CONFIGURATION ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Use "*" for development, specific origins for production
CORS_ORIGINS=*
# Production example:
# CORS_ORIGINS=https://your-frontend.azurestaticapps.net,https://your-custom-domain.com

# ─── LOGGING ───────────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# AZURE PRODUCTION DEPLOYMENT CHECKLIST
# =============================================================================
# 1. Set ENVIRONMENT=production
# 2. Generate and set a strong JWT_SECRET
# 3. Configure PostgreSQL (DATABASE_URL or individual POSTGRES_* variables)
# 4. Configure Azure Blob Storage (AZURE_STORAGE_CONNECTION_STRING)
# 5. Configure Qdrant Cloud (QDRANT_URL + QDRANT_API_KEY)
# 6. Set restrictive CORS_ORIGINS
# 7. Set LOG_LEVEL=WARNING or ERROR
# =============================================================================

# =============================================================================
# EXAMPLE PRODUCTION CONFIGURATION
# =============================================================================
# Uncomment and fill in for Azure production deployment:
#
# ENVIRONMENT=production
# JWT_SECRET=your-very-long-random-secret-key-minimum-32-chars
# JWT_EXPIRE_MINUTES=480
#
# DATABASE_URL=postgresql://ubisadmin:SecurePassword123!@ubis-prod.postgres.database.azure.com:5432/ubis?sslmode=require
#
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=ubisstorage;AccountKey=your-key;EndpointSuffix=core.windows.net
# AZURE_STORAGE_CONTAINER_UPLOADS=uploads
# AZURE_STORAGE_CONTAINER_REFERENCES=references
# AZURE_STORAGE_ACCOUNT_URL=https://ubisstorage.blob.core.windows.net
#
# QDRANT_URL=https://abc123.us-east-1.aws.cloud.qdrant.io:6333
# QDRANT_API_KEY=your-qdrant-api-key
# QDRANT_COLLECTION=face_embeddings
#
# CORS_ORIGINS=https://ubis-frontend.azurestaticapps.net
# LOG_LEVEL=WARNING
# =============================================================================
