# ============================================================================
# UBIS Production Environment Variables
# ============================================================================
# Copy this file to .env.production and fill in the values
# Usage: docker-compose -f docker-compose.production.yml --env-file .env.production up -d
# ============================================================================

# ─── GENERAL ───────────────────────────────────────────────────────────────────
ENVIRONMENT=production
PORT=8000
LOG_LEVEL=INFO

# ─── AZURE CONTAINER REGISTRY ──────────────────────────────────────────────────
ACR_NAME=ubisacr
TAG=latest

# ─── DATABASE: Azure Database for PostgreSQL ───────────────────────────────────
# Option 1: Full connection string (recommended)
DATABASE_URL=postgresql://ubisadmin:YOUR_PASSWORD@ubis-postgres.postgres.database.azure.com:5432/ubis?sslmode=require

# Option 2: Individual components (used if DATABASE_URL is empty)
POSTGRES_HOST=ubis-postgres.postgres.database.azure.com
POSTGRES_PORT=5432
POSTGRES_DB=ubis
POSTGRES_USER=ubisadmin
POSTGRES_PASSWORD=YOUR_PASSWORD

# ─── STORAGE: Azure Blob Storage ───────────────────────────────────────────────
# Get this from Azure Portal → Storage Account → Access Keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=ubisstorage;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_UPLOADS=uploads
AZURE_STORAGE_CONTAINER_REFERENCES=references

# ─── VECTOR DB: Local Qdrant ───────────────────────────────────────────────────
# Qdrant runs locally inside the container, persisted to Azure File Share for data safety.
# No managed vector DB, no Cosmos DB, no AI Search, no PGVector.
# This gives you full control and cost efficiency.
QDRANT_COLLECTION=face_embeddings
# QDRANT_URL is set by the compose file to /app/qdrant_storage

# ─── AUTHENTICATION ────────────────────────────────────────────────────────────
# IMPORTANT: Generate a strong secret for production!
# Run: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_A_SECURE_RANDOM_STRING
JWT_EXPIRE_MINUTES=1440

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=https://your-frontend-domain.com,https://ubis.azurewebsites.net
