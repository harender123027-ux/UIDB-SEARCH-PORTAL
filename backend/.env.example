SUBMISSIONS_STORAGE_PATH=./uploads
REFERENCE_PHOTOS_PATH=./reference_photos
# Qdrant: default is backend/qdrant_data (persistent, no Docker). Set :memory: for in-memory; http://localhost:6333 for Docker/server.
# QDRANT_URL=./qdrant_data
QDRANT_COLLECTION=face_embeddings
SQLITE_PATH=./ubis.db

# JWT (use a strong secret in production)
JWT_SECRET=change-me-in-production
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=1440

# Anonymous POST /api/feedback per client IP (signed-in users are not limited)
# FEEDBACK_ANONYMOUS_RATE_LIMIT=10
# FEEDBACK_ANONYMOUS_RATE_WINDOW_SEC=60
