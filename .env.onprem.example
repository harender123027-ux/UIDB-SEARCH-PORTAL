# UBIS on-prem environment file.
#
# On-prem install (one page): docs/HANDOVER_GURUGRAM/README.md
#
# 1. Copy this to ".env" beside docker-compose.onprem.yml:
#        cp .env.onprem.example .env
#
# 2. Generate strong values for the placeholders below:
#        bash scripts/onprem/generate_secrets.sh
#
# 3. Edit .env, replace the placeholders with the generated values.
#
# Never commit a filled-in .env to version control or send it by email.
# See docs/HANDOVER_GURUGRAM/07_SECRETS_GENERATION_METHODOLOGY.md.

# ── Web port the police users open in their browser ──
UBIS_HTTP_PORT=8080

# ── JWT (REQUIRED) — anything random & long, e.g. `openssl rand -hex 32` ──
JWT_SECRET=REPLACE_WITH_64_HEX_CHARACTERS
JWT_EXPIRE_MINUTES=1440

# ── Initial admin password (used the very first time the database is seeded) ──
# Generate with: openssl rand -base64 18 | tr -d '/=+' | head -c 20
# install.sh will set this for you automatically; only fill in by hand if you
# are bypassing the installer. After first login, change the password from the
# UI (Admin → Users) — the value here is NOT consulted again.
INITIAL_ADMIN_PASSWORD=REPLACE_WITH_STRONG_INITIAL_PASSWORD

# ── Logging ──
LOG_LEVEL=INFO
ENVIRONMENT=onprem

# ── CORS — leave * for the default same-origin nginx proxy. ──
CORS_ORIGINS=*

# ─────────────────────────────────────────────────────────────────────────────
# Only needed when you run `--profile full` (PostgreSQL).
# Leave commented for the default "lite" SQLite profile.
# DATABASE_URL=postgresql://ubis:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/ubis
# POSTGRES_DB=ubis
# POSTGRES_USER=ubis
# POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
# ─────────────────────────────────────────────────────────────────────────────
